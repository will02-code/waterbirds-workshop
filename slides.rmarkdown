## Package summary {.smaller}

- allows for using SWC as well (but the swc needs to be in the data - see workshop website)
- can group by wetland, valley, spp_code, and functional group
- specify which metric ("abundance", "richness", "nests", "broods", "nest_richness",  "pct_filled", or "simpson")

# Sample model 


## Load libraries and data

Cleaning code omitted

```{r}
#| message: false
#| warning: false
#| code-fold: true
#| label: "Load libraries and data"

# libraries
library(data.table)
library(brms)
# need to install this with install.packages("cmdstanr", repos = c('https://stan-dev.r-universe.dev', getOption("repos")))
library(cmdstanr)
# and also this, if you haven't run it already install_cmdstan()
library(eawsAnalysis) 
library(dplyr)
library(stringr)
library(ggplot2)
library(bayestestR)
library(tidybayes)
library(flextable)
my_theme <- function(title_size = 22, text_size = 20, ...) {
  theme_bw() +
    theme(
      plot.title = element_text(
        size = 22,
        face = "bold",
        colour = "black",
        family = "tachoma"
      ),
      strip.text = element_text(size = text_size),
      strip.background.x = element_rect(fill = "white", colour = "black"),
      axis.text = element_text(size = text_size, colour = "black"),
      axis.title = element_text(size = title_size, colour = "black"),
      legend.title = element_text(size = title_size, colour = "black"),
      legend.text = element_text(size = text_size, colour = "black"),
      ...
    )
}

#Spatial data
wetlands_with_valleys <- read.csv("data/wetlands_with_valleys.csv") 


# Rainfall data
asset_precip <- read.csv("data/asset_precip_data.csv")
valley_precip <- read.csv("data/valley_precip_data.csv")
precip <- read.csv("data/precip_data.csv")

# SWC (flooding) data
swc <- read.csv("data/australia_annual_water_area_presence.csv")
wetlands_swc <- read.csv("data/wetland_inundation_results.csv")
basin_swc <- read.csv("data/basin_inundation_results.csv") 
valleys_swc <- read.csv("data/valley_inundation_results.csv")

# Flow data
combined_flow_data <- read.csv("data/combined_flow_data.csv")
total_flow <- read.csv("data/total_flow.csv")

set.seed(123) 


# Waterbird data
data(data_clean)
# glimpse(data_clean)


```

## Get data using the `get_bird_data` function {.smaller}

```{r}
#| label: Load data and add environmental data in 
#| message: false
#| warning: false
#| code-fold: true
d <-
  get_bird_data(
    data_clean , # subset so that only years with all wetlands are included
    programs = c("MDB Combined"),
    metric = "abundance",
    wetlands = NULL,
    valleys = NULL,
    basinDiv = NULL,
    grouping_cols = 'Wetland'
  )


full_data <- d %>%
  left_join(
    asset_precip %>% mutate(Wetland = str_to_lower(Wetland)),
    join_by(surv_year == year, Wetland == Wetland)
  ) %>%
  left_join(wetlands_with_valleys) %>%
  mutate(ValleyName = str_to_lower(ValleyName)) %>%
  left_join(
    valley_precip,
    join_by(surv_year == year, ValleyName == valleyname)
  ) %>%
  left_join(precip, by = join_by("surv_year" == "year")) %>%
  left_join(
    combined_flow_data,
    by = join_by("surv_year" == "water_year", Wetland == wetlands)
  ) %>%
  filter(
    !is.na(wetland_flow_annual_scaled)
  ) %>%
  left_join(total_flow, by = join_by("surv_year" == "water_year")) %>%
  left_join(swc, join_by('surv_year' == "year")) %>%
  left_join(
    valleys_swc,
    join_by('surv_year' == "year", ValleyName == valley_name)
  ) %>%
  left_join(
    wetlands_swc,
    join_by('surv_year' == "year", Wetland == wetland_name)
  ) %>%
  left_join(basin_swc, join_by('surv_year' == "year")) %>%
  select(
    -c(subwetland,asset_precip_3m,asset_precip,X,valley_precip_3m,valley_precip,basin_precip_3m,basin_precip,flow_3m,flow,water_area_m2,inundated_area,inundated_area.x,inundated_area.y
    )
  ) %>%
  mutate(id = row_number())

glimpse(full_data)

```

## Run the model {.smaller}
```{r}
#| code-fold: true
#| label: "Set model formula"
#| echo: false
#| output: false
#| warning: false
#| message: false
full_formula <- brmsformula(
  value ~ asset_precip_3m_scaled + asset_precip_annual_scaled + asset_precip_annual_scaled_lagged + 
    valley_precip_3m_scaled +valley_precip_annual_scaled + valley_precip_annual_scaled_lagged + basin_precip_3m_scaled + basin_precip_annual_scaled + basin_precip_annual_scaled_lagged + 
    wetland_flow_3m_scaled + wetland_flow_annual_scaled + wetland_flow_annual_scaled_lagged + 
    total_basin_flow_3m_scaled + total_basin_flow_annual_scaled + total_basin_flow_annual_scaled_lagged + 
    swc_australia_scaled + swc_australia_scaled_lagged +
    (1 | Wetland), # random intercept for wetland
  # Same formula for the hurdle component of the model. 
  hu ~ asset_precip_3m_scaled + asset_precip_annual_scaled + asset_precip_annual_scaled_lagged + 
    valley_precip_3m_scaled +valley_precip_annual_scaled + valley_precip_annual_scaled_lagged + 
    basin_precip_3m_scaled + basin_precip_annual_scaled + basin_precip_annual_scaled_lagged + 
    wetland_flow_3m_scaled +wetland_flow_annual_scaled + wetland_flow_annual_scaled_lagged + 
    total_basin_flow_3m_scaled + total_basin_flow_annual_scaled + total_basin_flow_annual_scaled_lagged + swc_australia_scaled + swc_australia_scaled_lagged +
    (1 | Wetland)
)

priors <- c(
  set_prior(paste0("normal(", 9, ",", 1, ")"), class = "Intercept"),
  set_prior(paste0("normal(", 0, ",", 0.1, ")"), class = "b"),
  set_prior("exponential(2)", class = "shape"),
  set_prior("normal(1, 1)", class = "Intercept", dpar = "hu"),
  set_prior("normal(0, 0.1)", class = "b", dpar = "hu"),
  set_prior("normal(0, 0.5)", class = "sd", lb = 0),
  set_prior("normal(0, 0.5)", class = "sd", lb = 0, dpar = "hu")
)


m1.1_prior <- brm(
  formula = full_formula,
  family = hurdle_gamma(),
  data = full_data,
  backend = "cmdstanr",
  cores = 4,
  prior = priors,
  sample_prior = "only"
)


```

I have omitted some steps here, and jump straight to fitting the final model:

```{r}
#| message: false
#| warning: false
#| output: false
#| label: "Run model"
#| code-fold: true
m1.1 <- brm(
  full_formula,
  family = hurdle_gamma(),
  data = full_data,
  backend = "cmdstanr",
  cores = 4,
  prior = priors,
  chains = 4,
  iter = 4000,
  file = "data/m1.1.rds",
  file_refit = "on_change"
)

```

We should do some checking here before visualising model results. I have omitted both here, but see the workshop materials for details.

# Climate change analysis

## Walk through for one wetland {.scrollable}
```{r}
#| message: false
#| warning: false
#| label: "helper_functions"
#| echo: false
get_climate_predictions <- function(
  wetland,
  model,
  spp_code = NULL,
  fx_group = NULL,
  flow_metadata = combined_flow_metadata,
  climate_projections = valley_climate_projections_with_wetlands,
  basin_flow_stats = basin_flow_mean_sd
) {
  # --- Pre-processing -------------------------------------------------------
  scaling <- combined_flow_metadata |>
    filter(wetlands == wetland) |>
    slice(1) |>
    select(
      wetland_mean_flow_3m,
      wetland_sd_flow_3m,
      wetland_mean_flow_annual,
      wetland_sd_flow_annual
    )

  # --- Build scenario newdata -----------------------------------------------
  nuisance_vars <- c(
    "asset_precip_3m_scaled",
    "asset_precip_annual_scaled",
    "asset_precip_annual_scaled_lagged",
    "valley_precip_3m_scaled",
    "valley_precip_annual_scaled",
    "valley_precip_annual_scaled_lagged",
    "basin_precip_3m_scaled",
    "basin_precip_annual_scaled",
    "basin_precip_annual_scaled_lagged",
    "swc_australia_scaled",
    "swc_australia_scaled_lagged"
  )

  scenarios <- valley_climate_projections_with_wetlands |>
    filter(Wetland == wetland) |>
    arrange(Scenario) |>
    select(Scenario, pct_change) |>
    left_join(
      basin_flow_mean_sd |>
        select(Scenario, basin_flow_zscore_3m, basin_flow_zscore_annual),
      by = "Scenario"
    ) |>
    mutate(
      wetland_flow_3m_scaled = (scaling$wetland_mean_flow_3m * pct_change) /
        scaling$wetland_sd_flow_3m,
      wetland_flow_annual_scaled = (scaling$wetland_mean_flow_annual *
        pct_change) /
        scaling$wetland_sd_flow_annual,
      wetland_flow_annual_scaled_lagged = wetland_flow_annual_scaled,
      total_basin_flow_3m_scaled = basin_flow_zscore_3m,
      total_basin_flow_annual_scaled = basin_flow_zscore_annual,
      total_basin_flow_annual_scaled_lagged = basin_flow_zscore_annual,
      Wetland = wetland
    ) |>
    select(-basin_flow_zscore_3m, -basin_flow_zscore_annual)

  pred_newdata <- bind_rows(
    tibble(
      Scenario = "Baseline",
      pct_change = NA_real_,
      wetland_flow_3m_scaled = 0,
      wetland_flow_annual_scaled = 0,
      wetland_flow_annual_scaled_lagged = 0,
      total_basin_flow_3m_scaled = 0,
      total_basin_flow_annual_scaled = 0,
      total_basin_flow_annual_scaled_lagged = 0,
      Wetland = wetland
    ),
    scenarios
  )

  pred_newdata[nuisance_vars] <- 0

  if (!is.null(spp_code)) {
    pred_newdata$spp_code <- spp_code
  }
  if (!is.null(fx_group)) {
    pred_newdata$fx_group <- fx_group
  }

  # --- Posterior draws ------------------------------------------------------
  draws <- posterior_epred(model, newdata = pred_newdata, re_formula = NULL) |>
    t() |>
    as_tibble() |>
    mutate(scenario = pred_newdata$Scenario) |>
    pivot_longer(-scenario, names_to = ".draw", values_to = ".value")

  # --- Percent change (shared computation) ----------------------------------
  draws_with_pct <- draws |>
    group_by(.draw) |>
    mutate(
      baseline_val = .value[scenario == "Baseline"],
      percent_change = (.value - baseline_val) / baseline_val * 100
    ) |>
    ungroup()

  

  summary_results <- draws_with_pct |>
    group_by(scenario) |>
    median_hdci(percent_change, .value) |>
    mutate(wetland_name = wetland)
  if (!is.null(spp_code)) {
    summary_results$spp_code <- spp_code
  }
  if (!is.null(fx_group)) {
    summary_results$fx_group <- fx_group
  }
  list(
    summary = summary_results
  )
}




```

Again, data cleaning here was omitted. 

First we load in data
```{r}
#| message: false
#| warning: false
#| label: "libraries climate"
#| code-fold: true
library(dplyr)
library(tidyr)
library(ggplot2)
library(stringr)
library(eawsAnalysis)
library(sf)
library(brms)
library(tidybayes)
library(patchwork)

valley_climate_projections_with_wetlands <- read.csv("data/valley_climate_projections_with_wetlands.csv") |> 
    na.omit() # Scalars for each wetland, based on the valley it is located in for each climate scenario

combined_flow_metadata <- read.csv("data/combined_flow_metadata.csv") # This is the mean and sd for every wetland, based on the scaling we did for the models

basin_flow_mean_sd <- read.csv("data/basin_flow_mean_sd.csv") # This is the mean and sd for the basin flow, which we use for scaling the basin flow variables in the climate data
data(assets)
assets_coords <- assets %>%
  # Ensure we have the center point of each polygon
  mutate(centroid_lat = st_coordinates(st_centroid(geom))[, 2]) %>%
  st_drop_geometry() %>%
  # Sort by latitude descending (North to South)
  arrange(desc(centroid_lat)) %>%
  pull(Wetland) %>%
  str_to_lower()

```

Get the first wetland, and load in the model

```{r}
#| message: false
#| warning: false
#| label: "load_model"
#| code-fold: true
wetlands <- valley_climate_projections_with_wetlands |> 
  pull(Wetland) %>%
  unique() 
wetland <- wetlands[1]
overall_abund <- readr::read_rds("data/m1.1.rds")
print(paste0("Wetland: ", wetland))


```

We pull in scaling info, and scale the flow data for future climate scenarios

```{r}
#| message: false
#| warning: false
#| label: "scenarios"
#| code-fold: true

scaling <- combined_flow_metadata |>
    filter(wetlands == wetland) |>
    slice(1) |>
    select(
      wetland_mean_flow_3m,
      wetland_sd_flow_3m,
      wetland_mean_flow_annual,
      wetland_sd_flow_annual
    )

scenarios <- valley_climate_projections_with_wetlands |>
    filter(Wetland == wetland) |>
    arrange(Scenario) |>
    select(Scenario, pct_change) |>
    left_join(
      basin_flow_mean_sd |>
        select(Scenario, basin_flow_zscore_3m, basin_flow_zscore_annual),
      by = "Scenario"
    ) |>
    mutate(
      wetland_flow_3m_scaled = (scaling$wetland_mean_flow_3m * pct_change) /
        scaling$wetland_sd_flow_3m,
      wetland_flow_annual_scaled = (scaling$wetland_mean_flow_annual *
        pct_change) /
        scaling$wetland_sd_flow_annual,
      wetland_flow_annual_scaled_lagged = wetland_flow_annual_scaled,
      total_basin_flow_3m_scaled = basin_flow_zscore_3m,
      total_basin_flow_annual_scaled = basin_flow_zscore_annual,
      total_basin_flow_annual_scaled_lagged = basin_flow_zscore_annual,
      Wetland = wetland
    ) |>
    select(-basin_flow_zscore_3m, -basin_flow_zscore_annual)
```


## Walk through for one wetland {.smaller}

Then, we make a 'new' dataset
```{r}
#| message: false
#| warning: false
#| label: "predictors"
#| code-fold: true
nuisance_vars <- c(
    "asset_precip_3m_scaled",
    "asset_precip_annual_scaled",
    "asset_precip_annual_scaled_lagged",
    "valley_precip_3m_scaled",
    "valley_precip_annual_scaled",
    "valley_precip_annual_scaled_lagged",
    "basin_precip_3m_scaled",
    "basin_precip_annual_scaled",
    "basin_precip_annual_scaled_lagged",
    "swc_australia_scaled",
    "swc_australia_scaled_lagged"
  )

pred_newdata <- bind_rows(
    tibble(
        Scenario = "Baseline",
        pct_change = NA_real_,
        wetland_flow_3m_scaled = 0,
        wetland_flow_annual_scaled = 0,
        wetland_flow_annual_scaled_lagged = 0,
        total_basin_flow_3m_scaled = 0,
        total_basin_flow_annual_scaled = 0,
        total_basin_flow_annual_scaled_lagged = 0,
        Wetland = wetland
    ),
    scenarios
)

pred_newdata[nuisance_vars] <- 0

```


and predict!

```{r}
#| message: false
#| warning: false
#| label: "predictions"
#| code-fold: true
model <- overall_abund
draws <- posterior_epred(model, newdata = pred_newdata, re_formula = NULL) |>
    t() |>
    as_tibble() |>
    mutate(scenario = pred_newdata$Scenario) |>
    pivot_longer(-scenario, names_to = ".draw", values_to = ".value")

draws_with_pct <- draws |>
    group_by(.draw) |>
    mutate(
      baseline_val = .value[scenario == "Baseline"],
      percent_change = (.value - baseline_val) / baseline_val * 100
    ) |>
    ungroup()

  

summary_results <- draws_with_pct |>
    group_by(scenario) |>
    median_hdci(percent_change, .value, na.rm = TRUE) |>
    mutate(wetland_name = wetland)
summary_results |> 
    knitr::kable(digits = 2)


```


## Walk through for one wetland {.smaller}
and we can make some basic plots as well:

```{r}
#| message: false
#| warning: false
#| label: "plot"
#| code-fold: true
p1 <- ggplot(summary_results |> filter(scenario != "Baseline") |> mutate(scenario = factor(scenario, levels = c("S1", "S4", "S2", "S5", "S3", "S6"))), aes(x = scenario, y = percent_change)) +
    geom_point() +
    geom_errorbar(aes(ymin = percent_change.lower, ymax = percent_change.upper), width = 0.2) +
    labs(
        x = "Climate Scenario",
        y = "Percent Change from Baseline"
    ) +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))

p2 <- ggplot(summary_results  |> mutate(scenario = factor(scenario, levels = c("Baseline", "S1", "S4", "S2", "S5", "S3", "S6"))), aes(x = scenario, y = .value)) +
    geom_point() +
    geom_errorbar(aes(ymin = .value.lower, ymax = .value.upper), width = 0.2) +
    labs(
        x = "Climate Scenario",
        y = "Absolute Change"
    ) +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))
p1+p2
```

## All wetlands {.smaller}
For all wetlands, we made a simple function (see workshop website)
```{r}
#| message: false
#| warning: false
#| label: "all_wetlands"
#| code-fold: true

wetlands <- valley_climate_projections_with_wetlands |> 
  pull(Wetland) %>%
  unique() 

overall_abund <- readRDS("data/m1.1.rds")
results <- vector("list", length(wetlands))

for (i in 1:length(wetlands)) {
  # print(wetlands[i])
  
  results[[i]] <- get_climate_predictions(
    wetland = wetlands[i],
    model = overall_abund
  )
}

combined_df_overall <- purrr::map(results, "summary") %>% 
  bind_rows()
glimpse(combined_df_overall)

```

and we can also make a plot similar to those in the report (though a bit different!)

```{r}
#| message: false
#| warning: false
#| label: "plot_all_wetlands"
#| code-fold: true
p <- ggplot2::ggplot() +
    ggplot2::geom_pointrange(
  data = combined_df_overall |> filter(scenario != "Baseline") |> mutate(scenario = factor(scenario, levels = c("S1", "S4", "S2", "S5", "S3", "S6")), wetland_name = factor(wetland_name, levels = rev(assets_coords))),
  ggplot2::aes(
  x = percent_change,
  xmin = percent_change.lower,
  xmax = percent_change.upper,
  y = wetland_name
  ),
  # shape = 17,
  # size = 7
  ) +
    facet_wrap(~scenario, nrow = 1, scales = "free_x",labeller = ggplot2::label_wrap_gen(width = 18)) +
  ggplot2::geom_vline(xintercept = 0, linetype = "dashed", color = "black") +
  ggplot2::geom_hline(yintercept = 22.5, color = "black", size = 0.5, linetype = "dashed", alpha = 0.8) +
  ggplot2::scale_y_discrete(
    labels = str_to_title
  ) +
  my_theme() +
  ggplot2::labs(
  x = "Percent change",
  y = "Asset"
  ) +
  ggplot2::theme(
  axis.text.x = ggplot2::element_text(angle = 45, hjust = 1),
  panel.spacing = ggplot2::unit(2, "lines"),
  panel.background = ggplot2::element_rect(fill = "#F2F2F2"),
  plot.subtitle = ggplot2::element_text(size = 14),
  axis.text.y = ggtext::element_markdown(size = 24),
  legend.position = "none"
  ) 
```

